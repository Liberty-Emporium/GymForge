# GymForge — Environment Variables
# Copy this file to .env and fill in all values before running the project.

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL — must use django-tenants-compatible setup)
DB_NAME=gymforge_dev
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Railway provides this automatically in production
DATABASE_URL=

# Redis (Celery broker + result backend)
REDIS_URL=redis://localhost:6379/0

# Celery (dev only — set False to use real Celery worker)
CELERY_TASK_ALWAYS_EAGER=True

# Anthropic Claude AI
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# SendGrid (email via django-anymail)
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@gymforge.com
SERVER_EMAIL=errors@gymforge.com

# Cloudflare R2 (file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=

# Firebase Cloud Messaging (push notifications)
FCM_SERVER_KEY=
